{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/ai-dev-wal-entry.schema.json",
  "title": "AI Development WAL Entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "createdAt", "updatedAt", "unit", "intent", "actions", "evidence", "links"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable identifier for this entry. Convention: YYYY-MM-DD_<change-id>."
    },
    "createdAt": { "type": "string", "description": "ISO-8601 timestamp." },
    "updatedAt": { "type": "string", "description": "ISO-8601 timestamp." },
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "changeId"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["openspec-change", "decision", "incident", "release"]
        },
        "changeId": {
          "type": "string",
          "description": "OpenSpec change folder name (kebab-case)."
        },
        "milestone": { "type": "string" },
        "status": { "type": "string", "enum": ["planned", "in_progress", "done", "archived"] }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "whyNow"],
      "properties": {
        "summary": { "type": "string", "maxLength": 500 },
        "whyNow": { "type": "string", "maxLength": 1000 },
        "nonGoals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "decision", "rationale"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" } },
          "decision": { "type": "string" },
          "rationale": { "type": "string" },
          "risks": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filesTouched", "commandsRun"],
      "properties": {
        "filesTouched": { "type": "array", "items": { "type": "string" } },
        "commandsRun": { "type": "array", "items": { "type": "string" } },
        "testsRun": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validationStatus"],
      "properties": {
        "validationStatus": { "type": "string", "enum": ["pass", "fail", "partial", "unknown"] },
        "notes": { "type": "string" }
      }
    },
    "followUps": { "type": "array", "items": { "type": "string" } },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changePaths"],
      "properties": {
        "changePaths": { "type": "array", "items": { "type": "string" } },
        "commitShas": { "type": "array", "items": { "type": "string" } },
        "changelogPaths": { "type": "array", "items": { "type": "string" } },
        "roadmapPaths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "topics": { "type": "array", "items": { "type": "string" } }
  }
}

