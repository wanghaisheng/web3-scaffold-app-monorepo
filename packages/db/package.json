{
  "name": "@web3-scaffold/db",
  "version": "0.4.3",
  "private": true,
  "description": "web3-scaffold database package with SQLite migrations and Drizzle ORM type safety",
  "license": "MIT",
  "author": "web3-scaffold",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "bun run rm -rf dist *.tsbuildinfo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node simple-sql-runner.cjs",
    "db:reset": "node reset_and_migrate.cjs",
    "db:status": "sqlite3 dev.db \"SELECT migration_file, executed_at, success FROM migration_log ORDER BY executed_at DESC;\"",
    "db:tables": "sqlite3 dev.db \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\"",
    "db:studio": "drizzle-kit studio",
    "dev": "tsc -w",
    "lint": "eslint .  --max-warnings 0",
    "typecheck": "tsc",
    "test": "node run-all-tests.cjs",
    "test:unit": "bun test test/unit",
    "test:integration": "bun test test/integration",
    "test:functional": "bun test test/functional",
    "test:performance": "bun test test/performance",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:run": "bun test",
    "test:comprehensive": "bun test test/unit/comprehensive-schema-test.test.ts",
    "test:report": "node generate-test-report.cjs",
    "test:ci": "npm run test && npm run test:report",
    "test:quick": "bun test test/unit/basic-bun-test.test.ts test/unit/minimal-schema-test.test.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "drizzle-orm": "^0.33.0",
    "zod": "^3.23.8",
    "@web3-scaffold/env": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.24.2",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3"
  }
}
