{
  "name": "@web3-scaffold/auth",
  "version": "0.5.0",
  "private": true,
  "description": "Auth package for web3-scaffold using Better Auth",
  "license": "MIT",
  "author": "web3-scaffold",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "bun run rm -rf dist *.tsbuildinfo",
    "dev": "tsc -w -p tsconfig.build.json",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc"
  },
  "dependencies": {
    "better-auth": "^1.2.8",
    "zod": "^3.23.8",
    "@web3-scaffold/db": "workspace:^",
    "@web3-scaffold/env": "workspace:^",
    "@web3-scaffold/utils": "workspace:^"
  },
  "devDependencies": {
    "@web3-scaffold/eslint": "workspace:^",
    "@web3-scaffold/tsconfig": "workspace:^",
    "typescript": "^5.6.3"
  }
}
